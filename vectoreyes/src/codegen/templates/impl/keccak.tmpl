use std::convert::TryInto;

/// Keccak module providing functionality for Keccak-f[1600] permutation and SHA3-256 hash function
///
/// This implementation is based on the FIPS 202 standard:
/// https://nvlpubs.nist.gov/nistpubs/FIPS/NIST.FIPS.202.pdf
///
/// It provides support for:
/// - Keccak-f[1600] permutation function
/// - SHA3-256 hash function

/// State size for Keccak-f[1600] in bytes
pub const STATE_SIZE: usize = 200; // 1600 bits = 200 bytes

/// Lane size in bytes
pub const LANE_SIZE: usize = 8; // 64 bits = 8 bytes

/// Number of rounds for Keccak-f[1600]
pub const NUM_ROUNDS: usize = 24;

/// Delimiter for SHA3-256
pub const SHA3_DELIMITER: u8 = 0x06;

/// Rate for SHA3-256 in bytes
pub const SHA3_256_RATE: usize = 136; // 1088 bits

/// Round constants for Keccak-f permutation
const RC: [u64; NUM_ROUNDS] = [
    0x0000000000000001, 0x0000000000008082, 0x800000000000808a, 0x8000000080008000,
    0x000000000000808b, 0x0000000080000001, 0x8000000080008081, 0x8000000000008009,
    0x000000000000008a, 0x0000000000000088, 0x0000000080008009, 0x000000008000000a,
    0x000000008000808b, 0x800000000000008b, 0x8000000000008089, 0x8000000000008003,
    0x8000000000008002, 0x8000000000000080, 0x000000000000800a, 0x800000008000000a,
    0x8000000080008081, 0x8000000000008080, 0x0000000080000001, 0x8000000080008008,
];

/// Rotation offsets for rho step
const RHO_OFFSETS: [[usize; 5]; 5] = [
    [0, 1, 62, 28, 27],
    [36, 44, 6, 55, 20],
    [3, 10, 43, 25, 39],
    [41, 45, 15, 21, 8],
    [18, 2, 61, 56, 14],
];

/// Represents the 1600-bit state for Keccak-f[1600]
#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub struct KeccakState {
    /// State as 5x5 array of 64-bit lanes
    state: [[u64; 5]; 5],
}

impl Default for KeccakState {
    fn default() -> Self {
        Self {
            state: [[0; 5]; 5],
        }
    }
}

impl KeccakState {
    /// Creates a new Keccak state initialized to zero
    pub fn new() -> Self {
        Self::default()
    }

    /// Get a reference to the internal state
    pub fn get_state(&self) -> &[[u64; 5]; 5] {
        &self.state
    }

    /// Convert state to a byte array in little-endian format
    pub fn to_bytes(&self) -> [u8; STATE_SIZE] {
        let mut bytes = [0u8; STATE_SIZE];
        let mut offset = 0;

        for y in 0..5 {
            for x in 0..5 {
                let lane = self.state[x][y];
                for i in 0..8 {
                    bytes[offset + i] = (lane >> (8 * i)) as u8;
                }
                offset += 8;
            }
        }

        bytes
    }

    /// Load state from a byte array in little-endian format
    pub fn from_bytes(bytes: &[u8; STATE_SIZE]) -> Self {
        let mut state = Self::default();
        let mut offset = 0;

        for y in 0..5 {
            for x in 0..5 {
                let mut lane = 0u64;
                for i in 0..8 {
                    lane |= (bytes[offset + i] as u64) << (8 * i);
                }
                state.state[x][y] = lane;
                offset += 8;
            }
        }

        state
    }

    /// Apply the Keccak-f[1600] permutation
    pub fn permute(&mut self) {
        for round in 0..NUM_ROUNDS {
            // Theta step
            let mut c = [0u64; 5];
            for x in 0..5 {
                c[x] = self.state[x][0] ^ self.state[x][1] ^ self.state[x][2] ^ self.state[x][3] ^ self.state[x][4];
            }

            let mut d = [0u64; 5];
            for x in 0..5 {
                d[x] = c[(x + 4) % 5] ^ c[(x + 1) % 5].rotate_left(1);
            }

            for x in 0..5 {
                for y in 0..5 {
                    self.state[x][y] ^= d[x];
                }
            }

            // Rho and Pi steps combined
            let mut b = [[0u64; 5]; 5];
            for x in 0..5 {
                for y in 0..5 {
                    let new_x = y;
                    let new_y = (2 * x + 3 * y) % 5;
                    b[new_x][new_y] = self.state[x][y].rotate_left(RHO_OFFSETS[x][y] as u32);
                }
            }

            // Chi step
            for x in 0..5 {
                for y in 0..5 {
                    self.state[x][y] = b[x][y] ^ ((!b[(x + 1) % 5][y]) & b[(x + 2) % 5][y]);
                }
            }

            // Iota step
            self.state[0][0] ^= RC[round];
        }
    }

    /// Absorb input data into the state
    pub fn absorb(&mut self, input: &[u8], rate: usize) {
        let mut offset = 0;
        
        while offset + rate <= input.len() {
            // XOR block into state
            for i in 0..rate {
                let lane_index = i / 8;
                let x = lane_index % 5;
                let y = lane_index / 5;
                let z = i % 8;
                
                let shift = z * 8;
                let byte_value = (input[offset + i] as u64) << shift;
                
                self.state[x][y] ^= byte_value;
            }
            
            // Apply permutation
            self.permute();
            offset += rate;
        }
        
        // Handle remaining bytes (final block)
        if offset < input.len() {
            let remaining = input.len() - offset;
            
            // XOR remaining bytes
            for i in 0..remaining {
                let lane_index = i / 8;
                let x = lane_index % 5;
                let y = lane_index / 5;
                let z = i % 8;
                
                let shift = z * 8;
                let byte_value = (input[offset + i] as u64) << shift;
                
                self.state[x][y] ^= byte_value;
            }
        }
    }

    /// Squeeze output bytes from the state
    pub fn squeeze(&mut self, output: &mut [u8], rate: usize) {
        let mut offset = 0;
        
        while offset + rate <= output.len() {
            // Extract bytes from state
            for i in 0..rate {
                let lane_index = i / 8;
                let x = lane_index % 5;
                let y = lane_index / 5;
                let z = i % 8;
                
                let shift = z * 8;
                output[offset + i] = (self.state[x][y] >> shift) as u8;
            }
            
            // Apply permutation if more output needed
            if offset + rate < output.len() {
                self.permute();
            }
            
            offset += rate;
        }
        
        // Handle remaining bytes (final block)
        if offset < output.len() {
            let remaining = output.len() - offset;
            
            // Extract remaining bytes
            for i in 0..remaining {
                let lane_index = i / 8;
                let x = lane_index % 5;
                let y = lane_index / 5;
                let z = i % 8;
                
                let shift = z * 8;
                output[offset + i] = (self.state[x][y] >> shift) as u8;
            }
        }
    }

    /// Finalize absorption phase with appropriate padding
    pub fn pad(&mut self, rate: usize, position: usize, delimiter: u8) {
        // Apply delimited suffix at the current position
        let lane_index = position / 8;
        let x = lane_index % 5;
        let y = lane_index / 5;
        let z = position % 8;
        
        let shift = z * 8;
        let byte_value = (delimiter as u64) << shift;
        
        self.state[x][y] ^= byte_value;
        
        // Apply pad10*1 padding
        // Set MSB of last byte
        let last_byte_idx = rate - 1;
        let lane_index = last_byte_idx / 8;
        let x = lane_index % 5;
        let y = lane_index / 5;
        let z = last_byte_idx % 8;
        
        let shift = z * 8;
        let mask = 0x80u64 << shift;
        
        self.state[x][y] ^= mask;
        
        // Apply permutation
        self.permute();
    }
}

/// Hasher implementation for SHA3 variants
#[derive(Debug, Clone)]
pub struct Sha3 {
    /// Internal Keccak state
    state: KeccakState,
    /// Rate in bytes
    rate: usize,
    /// Delimiter for this SHA-3 variant
    delimiter: u8,
    /// Current position in the buffer
    position: usize,
    /// Buffer for partial blocks (fixed size to avoid allocations)
    buffer: [u8; SHA3_256_RATE],
    /// Is the hasher finalized?
    finalized: bool,
}

impl Sha3 {
    /// Create a new SHA3 hasher with the specified rate and delimiter
    fn new(rate: usize, delimiter: u8) -> Self {
        Self {
            state: KeccakState::new(),
            rate,
            delimiter,
            position: 0,
            buffer: [0; SHA3_256_RATE],
            finalized: false,
        }
    }

    /// Create a new SHA3-256 hasher
    pub fn sha3_256() -> Self {
        Self::new(SHA3_256_RATE, SHA3_DELIMITER)
    }

    /// Update the hasher with input data
    pub fn update(&mut self, input: &[u8]) {
        if self.finalized {
            panic!("Cannot update a finalized hasher");
        }

        let mut input_offset = 0;

        // If there's data in the buffer, fill it first
        if self.position > 0 {
            let to_copy = std::cmp::min(self.rate - self.position, input.len());
            self.buffer[self.position..self.position + to_copy].copy_from_slice(&input[..to_copy]);
            self.position += to_copy;
            input_offset += to_copy;

            // If buffer is full, absorb it
            if self.position == self.rate {
                self.state.absorb(&self.buffer, self.rate);
                self.position = 0;
            }
        }

        // Process full blocks directly from input
        let remaining = input.len() - input_offset;
        let full_blocks = remaining / self.rate;
        
        if full_blocks > 0 {
            let full_blocks_size = full_blocks * self.rate;
            self.state.absorb(&input[input_offset..input_offset + full_blocks_size], self.rate);
            input_offset += full_blocks_size;
        }

        // Store remaining input in buffer
        let remaining = input.len() - input_offset;
        if remaining > 0 {
            self.buffer[0..remaining].copy_from_slice(&input[input_offset..]);
            self.position = remaining;
        }
    }

    /// Finalize the hasher and return the digest
    pub fn finalize(&mut self, output_len: usize) -> Vec<u8> {
        if !self.finalized {
            // According to FIPS 202, the SHA-3 padding rule is:
            // 1. Append the bits 01 (for SHA-3)
            // 2. Append a bit 1
            // 3. Append zero or more bits 0, followed by a bit 1
            
            // Create a final block using our existing buffer
            let mut final_block = [0u8; SHA3_256_RATE];
            
            // Copy existing data from buffer
            final_block[..self.position].copy_from_slice(&self.buffer[..self.position]);
            
            // Add the delimiter byte (0x06 = 00000110b for SHA-3)
            // This includes the domain separator (01) and the first padding bit (1)
            final_block[self.position] = self.delimiter;
            
            // Add the final padding bit (1) at the end of the block
            final_block[self.rate - 1] |= 0x80;
            
            // Absorb the final block
            self.state.absorb(&final_block[..self.rate], self.rate);
            self.finalized = true;
        }

        // Squeeze output
        let mut output = vec![0; output_len];
        self.state.squeeze(&mut output, self.rate);
        output
    }

    /// Convenience method for SHA3-256
    pub fn sha3_256_hash(input: &[u8]) -> [u8; 32] {
        let mut hasher = Self::sha3_256();
        hasher.update(input);
        let result = hasher.finalize(32);
        result.try_into().expect("Output length is incorrect")
    }
}

/// Converts a 1600-bit state as a boolean array to a KeccakState struct
pub fn bool_array_to_keccak_state(bits: &[bool; 1600]) -> KeccakState {
    let mut bytes = [0u8; STATE_SIZE];
    
    for i in 0..1600 {
        if bits[i] {
            bytes[i / 8] |= 1 << (i % 8);
        }
    }
    
    KeccakState::from_bytes(&bytes)
}

/// Converts a KeccakState struct to a 1600-bit boolean array 
pub fn keccak_state_to_bool_array(state: &KeccakState) -> [bool; 1600] {
    let bytes = state.to_bytes();
    let mut bits = [false; 1600];
    
    for i in 0..1600 {
        bits[i] = (bytes[i / 8] & (1 << (i % 8))) != 0;
    }
    
    bits
}

/// Apply the Keccak-f[1600] permutation to a 1600-bit boolean array
pub fn keccak_f1600_permutation(state: &mut [bool; 1600]) {
    // Convert to KeccakState for processing
    let mut keccak_state = bool_array_to_keccak_state(state);
    
    // Apply permutation
    keccak_state.permute();
    
    // Convert back to boolean array
    *state = keccak_state_to_bool_array(&keccak_state);
}

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_keccak_permutation() {
        // Start with zero state
        let mut state = KeccakState::new();
        
        // Set a simple pattern (just set the first byte to 1)
        let mut bytes = [0u8; STATE_SIZE];
        bytes[0] = 1;
        state = KeccakState::from_bytes(&bytes);
        
        // Apply permutation
        state.permute();
        
        // Ensure state changed
        assert_ne!(state, KeccakState::new());
    }

    #[test]
    fn test_sha3_256() {
        // Test vector from NIST
        let input = b"";
        let expected = hex::decode("a7ffc6f8bf1ed76651c14756a061d662f580ff4de43b49fa82d80a4b80f8434a").unwrap();
        
        let hash = Sha3::sha3_256_hash(input);
        assert_eq!(hash.to_vec(), expected);
        
        // Another test vector
        let input = b"abc";
        let expected = hex::decode("3a985da74fe225b2045c172d6bd390bd855f086e3e9d525b46bfe24511431532").unwrap();
        
        let hash = Sha3::sha3_256_hash(input);
        assert_eq!(hash.to_vec(), expected);
    }

}
